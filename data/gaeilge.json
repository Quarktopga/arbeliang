          { "type": "card", "id": "ga_c2_word_haon", "fr": "Un (1)", "target": "A haon" },
          { "id": "ga_c2_v_7", "type": "qcm", "q": "Que signifie « A haon » ?", "options": ["Un", "Deux", "Trois"], "a": "Un" },
          { "id": "ga_c2_v_8", "type": "strict", "q": "Traduisez le chiffre : Un", "a": ["A haon"] },

          { "type": "card", "id": "ga_c2_word_ado", "fr": "Deux (2)", "target": "A dó" },
          { "id": "ga_c2_v_9", "type": "qcm", "q": "Que signifie « A dó » ?", "options": ["Un", "Deux", "Quatre"], "a": "Deux" },
          { "id": "ga_c2_v_10", "type": "strict", "q": "Traduisez le chiffre : Deux", "a": ["A dó"] },

          { "type": "card", "id": "ga_c2_word_atri", "fr": "Trois (3)", "target": "A trí" },
          { "id": "ga_c2_v_11", "type": "qcm", "q": "Que signifie « A trí » ?", "options": ["Trois", "Cinq", "Deux"], "a": "Trois" },
          { "id": "ga_c2_v_12", "type": "strict", "q": "Traduisez le chiffre : Trois", "a": ["A trí"] },

          { "id": "ga_c2_v_13", "type": "qcm", "hard": true, "q": "Comment dirait-on « Ma famille » ? (indice : mo = mon/ma)", "options": ["Mo theaghlach", "Teaghlach mo", "Teaghlach mé"], "a": "Mo theaghlach" },
          { "id": "ga_c2_v_14", "type": "strict", "q": "Traduisez : Un, deux, trois", "a": ["A haon, a dó, a trí"] },
          { "id": "ga_c2_v_15", "type": "qcm", "q": "Quel mot désigne le père en irlandais ?", "options": ["Mam", "Daid", "Teaghlach"], "a": "Daid" },
          { "id": "ga_c2_v_16", "type": "strict", "hard": true, "q": "Traduisez : Maman et Papa", "a": ["Mam agus Daid"] }
        ],
        "grammar": [
          { "type": "gcard", "id": "ga_c2_g_card1", "title": "La mutation initiale (séimhiú)", "content": "Particularité du gaélique : certains mots déclenchent une mutation de la consonne initiale du mot suivant (« séimhiú », ajout d'un h). Par exemple, après « mo » (mon/ma) : teaghlach → mo theaghlach." },
          { "id": "ga_c2_g_1", "type": "qcm", "q": "Que se passe-t-il après « mo » (mon/ma) sur le mot qui suit ?", "options": ["Une mutation (séimhiú)", "Rien du tout", "Le mot devient pluriel"], "a": "Une mutation (séimhiú)" },
          { "id": "ga_c2_g_2", "type": "strict", "q": "Complétez : mo theaghlach = ma ___", "a": ["famille"] },

          { "type": "gcard", "id": "ga_c2_g_card2", "title": "Les adjectifs possessifs", "content": "Mo (mon/ma) + mutation, do (ton/ta) + mutation également. Exemple : do Mham (ta maman), mo Dhaid (mon papa)." },
          { "id": "ga_c2_g_3", "type": "qcm", "q": "Comment dit-on « ta maman » ?", "options": ["do Mham", "mo Mham", "Mham do"], "a": "do Mham" },
          { "id": "ga_c2_g_4", "type": "strict", "q": "Traduisez : Mon papa", "a": ["Mo Dhaid"] },
          { "id": "ga_c2_g_5", "type": "qcm", "hard": true, "q": "Quelle forme utiliser pour dire « ma famille » ?", "options": ["mo theaghlach", "do theaghlach", "teaghlach mo"], "a": "mo theaghlach" },

          { "type": "gcard", "id": "ga_c2_g_card3", "title": "Compter avec « a »", "content": "En irlandais, les nombres cardinaux isolés se disent avec « a » devant : a haon (un), a dó (deux), a trí (trois). Mais devant un nom, la forme change (ex : trí theach = trois maisons)." },
          { "id": "ga_c2_g_6", "type": "qcm", "q": "Comment dit-on « un » de façon isolée (en comptant) ?", "options": ["A haon", "Haon", "Aon"], "a": "A haon" },
          { "id": "ga_c2_g_7", "type": "strict", "q": "Traduisez le chiffre isolé : Deux", "a": ["A dó"] },
          { "id": "ga_c2_g_8", "type": "qcm", "q": "Quelle phrase est correcte pour « Ma famille est grande » (mór = grand) ?", "options": ["Tá mo theaghlach mór", "Mo theaghlach tá mór", "Mór tá mo theaghlach"], "a": "Tá mo theaghlach mór" },
          { "id": "ga_c2_g_9", "type": "strict", "hard": true, "q": "Traduisez : Ma famille est grande (utilisez 'Tá mo theaghlach mór')", "a": ["Tá mo theaghlach mór"] },
          { "id": "ga_c2_g_10", "type": "qcm", "q": "Quel est le mot pour « famille » en irlandais ?", "options": ["Teaghlach", "Clann", "Muintir"], "a": "Teaghlach" }
        ],
        "reading": [
          { "type": "gcard", "id": "ga_c2_r_intro", "title": "Compréhension : Ma famille", "content": "Lisez le texte suivant :\nIs mise Lisa. Níl mo theaghlach mór: Mam, Daid agus mé féin. Táimid triúr. Tá cat agam freisin. A haon, a dó, a trí - táimid ceathrar leis an gcat!\n\n(Indice : níl...mór = n'est pas grand, triúr = trois personnes, cat = chat, ceathrar = quatre personnes)" },
          { "id": "ga_c2_r_1", "type": "qcm", "q": "Comment s'appelle la personne qui parle ?", "options": ["Anna", "Lisa", "Erik"], "a": "Lisa" },
          { "id": "ga_c2_r_2", "type": "qcm", "q": "Combien de personnes composent la famille (sans le chat) ?", "options": ["Deux", "Trois", "Quatre"], "a": "Trois" },
          { "id": "ga_c2_r_3", "type": "strict", "q": "D'après le texte, traduisez : chat", "a": ["cat"] },
          { "id": "ga_c2_r_4", "type": "qcm", "q": "Que signifie « níl...mór » dans le texte ?", "options": ["n'est pas grand", "est très grand", "est aussi grand"], "a": "n'est pas grand" },
          { "id": "ga_c2_r_5", "type": "qcm", "hard": true, "q": "Combien sont-ils en comptant le chat ?", "options": ["Trois (triúr)", "Quatre (ceathrar)", "Cinq"], "a": "Quatre (ceathrar)" },
          { "id": "ga_c2_r_6", "type": "strict", "q": "Traduisez la phrase du texte : Nous sommes trois (utilisez 'Táimid triúr')", "a": ["Táimid triúr"] },
          { "id": "ga_c2_r_7", "type": "qcm", "q": "La famille de Lisa est-elle décrite comme grande ?", "options": ["Oui, elle est grande", "Non, elle n'est pas grande", "Ce n'est pas précisé"], "a": "Non, elle n'est pas grande" },
          { "id": "ga_c2_r_8", "type": "qcm", "q": "Quel animal Lisa possède-t-elle ?", "options": ["Un chien", "Un chat", "Un oiseau"], "a": "Un chat" },
          { "id": "ga_c2_r_9", "type": "strict", "hard": true, "q": "Complétez d'après le texte : « Tá ___ agam freisin » (j'ai aussi un chat)", "a": ["cat"] },
          { "id": "ga_c2_r_10", "type": "qcm", "q": "Quel est le sujet principal du texte ?", "options": ["Les nombres", "La présentation de la famille de Lisa", "Les animaux domestiques en Irlande"], "a": "La présentation de la famille de Lisa" }
        ],
        "review": [
          { "id": "ga_c2_rev_1", "type": "qcm", "q": "Que signifie « Teaghlach » ?", "options": ["Ami", "Famille", "Voisin"], "a": "Famille" },
          { "id": "ga_c2_rev_2", "type": "strict", "q": "Traduisez : Papa", "a": ["Daid"] },
          { "id": "ga_c2_rev_3", "type": "qcm", "q": "Comment dit-on « trois » (isolé) ?", "options": ["A haon", "A dó", "A trí"], "a": "A trí" },
          { "id": "ga_c2_rev_4", "type": "strict", "q": "Traduisez : Ma famille", "a": ["Mo theaghlach"] },
          { "id": "ga_c2_rev_5", "type": "qcm", "hard": true, "q": "Quelle forme pour dire « ta maman » ?", "options": ["do Mham", "mo Mham"], "a": "do Mham" },
          { "id": "ga_c2_rev_6", "type": "strict", "q": "Traduisez : Nous sommes trois (utilisez 'Táimid triúr')", "a": ["Táimid triúr"] },
          { "id": "ga_c2_rev_7", "type": "qcm", "q": "Que signifie « cat » ?", "options": ["Chien", "Chat", "Oiseau"], "a": "Chat" },
          { "id": "ga_c2_rev_8", "type": "strict", "q": "Traduisez : Ma famille est grande (utilisez 'Tá mo theaghlach mór')", "a": ["Tá mo theaghlach mór"] },
          { "id": "ga_c2_rev_9", "type": "qcm", "hard": true, "q": "Comment appelle-t-on la mutation qui suit « mo » ?", "options": ["Séimhiú", "Urú", "Pluriel"], "a": "Séimhiú" },
          { "id": "ga_c2_rev_10", "type": "qcm", "q": "Que signifie « níl...mór » ?", "options": ["n'est pas grand", "est toujours grand", "n'est jamais petit"], "a": "n'est pas grand" }
        ]
