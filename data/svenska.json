        "grammar": [
          { "type": "gcard", "id": "sv_c1_g_card1", "title": "Le genre neutre : « ett »", "content": "En suédois, certains noms sont neutres et utilisent l'article « ett ». Exemple : ett barn (un enfant). Il faut apprendre le genre avec chaque nouveau mot." },
          { "id": "sv_c1_g_1", "type": "qcm", "q": "Quel article utilise-t-on pour « barn » (enfant) ?", "options": ["en", "ett", "den"], "a": "ett" },
          { "id": "sv_c1_g_2", "type": "strict", "q": "Traduisez : un enfant", "a": ["ett barn"] },

          { "type": "gcard", "id": "sv_c1_g_card2", "title": "Le genre commun : « en »", "content": "D'autres noms sont communs et utilisent l'article « en ». Exemple : en vän (un ami/une amie). Environ 75% des noms suédois sont des en-mots." },
          { "id": "sv_c1_g_3", "type": "qcm", "q": "Quel article utilise-t-on pour « vän » (ami) ?", "options": ["en", "ett", "de"], "a": "en" },
          { "id": "sv_c1_g_4", "type": "qcm", "q": "Parmi ces deux mots, lequel est un « en-mot » ?", "options": ["vän", "barn"], "a": "vän" },

          { "type": "gcard", "id": "sv_c1_g_card3", "title": "Les pronoms et le verbe « vara » (être)", "content": "Jag (je), du (tu), han (il), hon (elle). Le verbe « vara » (être) ne change jamais selon la personne : Jag är, Du är, Han är, Hon är." },
          { "id": "sv_c1_g_5", "type": "strict", "q": "Traduisez : Je suis", "a": ["Jag är"] },
          { "id": "sv_c1_g_6", "type": "qcm", "q": "Comment dit-on « il est » ?", "options": ["Han är", "Hon är", "Du är"], "a": "Han är" },

          { "id": "sv_c1_g_7", "type": "strict", "q": "Traduisez : Tu es un ami.", "a": ["Du är en vän", "Du är en vän."] },
          { "id": "sv_c1_g_8", "type": "strict", "q": "Traduisez : Elle est une enfant.", "a": ["Hon är ett barn", "Hon är ett barn."] },

          { "id": "sv_c1_g_9", "type": "strict", "hard": true, "q": "Traduisez cette phrase : Bonjour, je suis un ami.", "a": ["Hej, jag är en vän.", "Hej, jag är en vän"] },
          { "id": "sv_c1_g_10", "type": "strict", "hard": true, "q": "Traduisez cette phrase : Oui, elle est une enfant.", "a": ["Ja, hon är ett barn.", "Ja, hon är ett barn"] }
        ],
