{
  "debutant": [
    {
      "chapterId": "c1",
      "title": "Chapitre 1 : Les Salutations & Mots de Base",
      "lessons": {
        "vocab": [
          { "type": "card", "id": "sv_c1_word_hej", "fr": "Bonjour", "target": "Hej" },
          { "id": "sv_c1_v_1", "type": "qcm", "q": "Que signifie « Hej » ?", "options": ["Au revoir", "Bonjour", "Merci"], "a": "Bonjour" },
          { "id": "sv_c1_v_2", "type": "strict", "q": "Traduisez : Bonjour", "a": ["Hej"] },

          { "type": "card", "id": "sv_c1_word_hejda", "fr": "Au revoir", "target": "Hej då" },
          { "id": "sv_c1_v_3", "type": "qcm", "q": "Que signifie « Hej då » ?", "options": ["Bonjour", "Au revoir", "S'il te plaît"], "a": "Au revoir" },
          { "id": "sv_c1_v_4", "type": "strict", "q": "Traduisez : Au revoir", "a": ["Hej då"] },

          { "type": "card", "id": "sv_c1_word_tack", "fr": "Merci", "target": "Tack" },
          { "id": "sv_c1_v_5", "type": "qcm", "q": "Que signifie « Tack » ?", "options": ["Merci", "Pardon", "Bonjour"], "a": "Merci" },
          { "id": "sv_c1_v_6", "type": "strict", "q": "Traduisez : Merci", "a": ["Tack"] },

          { "type": "card", "id": "sv_c1_word_varsagod", "fr": "Je t'en prie / Voici", "target": "Varsågod" },
          { "id": "sv_c1_v_7", "type": "qcm", "q": "Que signifie « Varsågod » ?", "options": ["Je t'en prie", "Excuse-moi", "Bonsoir"], "a": "Je t'en prie" },
          { "id": "sv_c1_v_8", "type": "strict", "q": "Traduisez : Je t'en prie", "a": ["Varsågod"] },

          { "type": "card", "id": "sv_c1_word_ja", "fr": "Oui", "target": "Ja" },
          { "id": "sv_c1_v_9", "type": "qcm", "q": "Que signifie « Ja » ?", "options": ["Non", "Oui", "Peut-être"], "a": "Oui" },
          { "id": "sv_c1_v_10", "type": "strict", "q": "Traduisez : Oui", "a": ["Ja"] },

          { "type": "card", "id": "sv_c1_word_nej", "fr": "Non", "target": "Nej" },
          { "id": "sv_c1_v_11", "type": "qcm", "q": "Que signifie « Nej » ?", "options": ["Oui", "Non", "Merci"], "a": "Non" },
          { "id": "sv_c1_v_12", "type": "strict", "q": "Traduisez : Non", "a": ["Nej"] },

          { "id": "sv_c1_v_13", "type": "qcm", "hard": true, "q": "Laquelle de ces paires est correcte (salutation / réponse) ?", "options": ["Hej / Hej då", "Tack / Varsågod", "Ja / Tack"], "a": "Tack / Varsågod" },
          { "id": "sv_c1_v_14", "type": "strict", "q": "Traduisez : Non, merci", "a": ["Nej, tack"] },
          { "id": "sv_c1_v_15", "type": "qcm", "q": "Comment dit-on « Bonjour » de façon informelle en suédois courant ?", "options": ["Hej", "God dag", "Hallå"], "a": "Hej" },
          { "id": "sv_c1_v_16", "type": "strict", "hard": true, "q": "Traduisez : Oui, merci", "a": ["Ja, tack"] }
        ],
        "grammar": [
          { "type": "gcard", "id": "sv_c1_g_card1", "title": "L'article indéfini", "content": "En suédois, il existe deux genres grammaticaux : le commun (en) et le neutre (ett). « en bok » (un livre), « ett hus » (une maison). Il n'y a pas de règle simple : il faut apprendre le genre avec chaque mot." },
          { "id": "sv_c1_g_1", "type": "qcm", "q": "Quel article utilise-t-on pour « hus » (maison) ?", "options": ["en", "ett", "den"], "a": "ett" },
          { "id": "sv_c1_g_2", "type": "qcm", "q": "Quel article utilise-t-on pour « bok » (livre) ?", "options": ["en", "ett", "de"], "a": "en" },

          { "type": "gcard", "id": "sv_c1_g_card2", "title": "Le verbe « vara » (être)", "content": "« Vara » signifie être. Contrairement au français, il ne se conjugue pas selon la personne : Jag är (je suis), Du är (tu es), Han/Hon är (il/elle est), Vi är (nous sommes)." },
          { "id": "sv_c1_g_3", "type": "strict", "q": "Traduisez : Je suis (utilisez 'vara')", "a": ["Jag är"] },
          { "id": "sv_c1_g_4", "type": "qcm", "q": "Comment dit-on « tu es » ?", "options": ["Du är", "Jag är", "Vi är"], "a": "Du är" },
          { "id": "sv_c1_g_5", "type": "strict", "hard": true, "q": "Traduisez : Nous sommes (utilisez 'vara')", "a": ["Vi är"] },

          { "type": "gcard", "id": "sv_c1_g_card3", "title": "L'ordre des mots de base", "content": "L'ordre standard est Sujet-Verbe-Objet, comme en français : « Jag talar svenska » (Je parle suédois)." },
          { "id": "sv_c1_g_6", "type": "qcm", "q": "Quel est l'ordre correct pour « Je parle suédois » ?", "options": ["Jag talar svenska", "Talar jag svenska", "Svenska jag talar"], "a": "Jag talar svenska" },
          { "id": "sv_c1_g_7", "type": "strict", "q": "Traduisez : Il est (utilisez 'vara')", "a": ["Han är"] },
          { "id": "sv_c1_g_8", "type": "qcm", "hard": true, "q": "Quelle phrase est grammaticalement correcte ?", "options": ["Hon är svensk", "Hon svensk är", "Är hon svensk (affirmatif)"], "a": "Hon är svensk" },
          { "id": "sv_c1_g_9", "type": "strict", "q": "Traduisez : Elle est (utilisez 'vara')", "a": ["Hon är"] },
          { "id": "sv_c1_g_10", "type": "qcm", "q": "Quel article pour « äpple » (pomme, neutre) ?", "options": ["en", "ett"], "a": "ett" }
        ],
        "reading": [
          { "type": "gcard", "id": "sv_c1_r_intro", "title": "Compréhension : Une rencontre", "content": "Lisez le dialogue suivant :\n— Hej! Jag heter Anna.\n— Hej då! Nej, jag heter Erik.\n— Tack, Erik. Vi är vänner nu.\n\n(Traduction indicative : Bonjour, je m'appelle Anna. / Bonjour(?), non, je m'appelle Erik. / Merci Erik, nous sommes amis maintenant.)" },
          { "id": "sv_c1_r_1", "type": "qcm", "q": "Comment s'appelle la première personne ?", "options": ["Anna", "Erik", "Lena"], "a": "Anna" },
          { "id": "sv_c1_r_2", "type": "qcm", "q": "Que répond Erik après « Hej! » ?", "options": ["Hej då", "Tack", "Ja"], "a": "Hej då" },
          { "id": "sv_c1_r_3", "type": "strict", "q": "D'après le dialogue, traduisez : je m'appelle (verbe seul)", "a": ["heter", "jag heter"] },
          { "id": "sv_c1_r_4", "type": "qcm", "q": "Que veut dire « vänner » dans le contexte ?", "options": ["Amis", "Ennemis", "Voisins"], "a": "Amis" },
          { "id": "sv_c1_r_5", "type": "qcm", "hard": true, "q": "Quel mot du dialogue signifie « maintenant » ?", "options": ["nu", "då", "än"], "a": "nu" },
          { "id": "sv_c1_r_6", "type": "strict", "q": "Traduisez la phrase : Nous sommes amis", "a": ["Vi är vänner"] },
          { "id": "sv_c1_r_7", "type": "qcm", "q": "Quel est le ton général du dialogue ?", "options": ["Formel et distant", "Amical et informel", "Conflictuel"], "a": "Amical et informel" },
          { "id": "sv_c1_r_8", "type": "qcm", "q": "Qui remercie qui dans le dialogue ?", "options": ["Anna remercie Erik", "Erik remercie Anna", "Personne ne remercie"], "a": "Anna remercie Erik" },
          { "id": "sv_c1_r_9", "type": "strict", "hard": true, "q": "Complétez d'après le dialogue : « Jag ___ Anna » (je m'appelle)", "a": ["heter"] },
          { "id": "sv_c1_r_10", "type": "qcm", "q": "Combien de personnes parlent dans ce dialogue ?", "options": ["Une", "Deux", "Trois"], "a": "Deux" }
        ],
        "review": [
          { "id": "sv_c1_rev_1", "type": "qcm", "q": "Que signifie « Hej » ?", "options": ["Au revoir", "Bonjour", "Merci"], "a": "Bonjour" },
          { "id": "sv_c1_rev_2", "type": "strict", "q": "Traduisez : Merci", "a": ["Tack"] },
          { "id": "sv_c1_rev_3", "type": "qcm", "q": "Quel article pour « hus » (maison) ?", "options": ["en", "ett"], "a": "ett" },
          { "id": "sv_c1_rev_4", "type": "strict", "q": "Traduisez : Je suis", "a": ["Jag är"] },
          { "id": "sv_c1_rev_5", "type": "qcm", "q": "Comment dit-on « Non » ?", "options": ["Ja", "Nej", "Tack"], "a": "Nej" },
          { "id": "sv_c1_rev_6", "type": "strict", "hard": true, "q": "Traduisez la phrase : Nous sommes amis", "a": ["Vi är vänner"] },
          { "id": "sv_c1_rev_7", "type": "qcm", "q": "Que signifie « Varsågod » ?", "options": ["Je t'en prie", "Bonsoir", "Excuse-moi"], "a": "Je t'en prie" },
          { "id": "sv_c1_rev_8", "type": "strict", "q": "Traduisez : Au revoir", "a": ["Hej då"] },
          { "id": "sv_c1_rev_9", "type": "qcm", "hard": true, "q": "Quelle est la structure correcte de phrase en suédois ?", "options": ["Sujet-Verbe-Objet", "Objet-Sujet-Verbe", "Verbe-Sujet-Objet"], "a": "Sujet-Verbe-Objet" },
          { "id": "sv_c1_rev_10", "type": "strict", "q": "Traduisez : Oui, merci", "a": ["Ja, tack"] }
        ]
      }
    },
