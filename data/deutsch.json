          { "id": "de_c2_v_1", "type": "qcm", "q": "Que signifie « Familie » ?", "options": ["Famille", "Ami", "Maison"], "a": "Famille" },
          { "id": "de_c2_v_2", "type": "strict", "q": "Traduisez : Famille", "a": ["Familie"] },

          { "type": "card", "id": "de_c2_word_mama", "fr": "Maman", "target": "Mama" },
          { "id": "de_c2_v_3", "type": "qcm", "q": "Que signifie « Mama » ?", "options": ["Papa", "Maman", "Sœur"], "a": "Maman" },
          { "id": "de_c2_v_4", "type": "strict", "q": "Traduisez : Maman", "a": ["Mama"] },

          { "type": "card", "id": "de_c2_word_papa", "fr": "Papa", "target": "Papa" },
          { "id": "de_c2_v_5", "type": "qcm", "q": "Que signifie « Papa » ?", "options": ["Papa", "Maman", "Frère"], "a": "Papa" },
          { "id": "de_c2_v_6", "type": "strict", "q": "Traduisez : Papa", "a": ["Papa"] },

          { "type": "card", "id": "de_c2_word_eins", "fr": "Un (1)", "target": "Eins" },
          { "id": "de_c2_v_7", "type": "qcm", "q": "Que signifie « Eins » ?", "options": ["Un", "Deux", "Trois"], "a": "Un" },
          { "id": "de_c2_v_8", "type": "strict", "q": "Traduisez le chiffre : Un", "a": ["Eins"] },

          { "type": "card", "id": "de_c2_word_zwei", "fr": "Deux (2)", "target": "Zwei" },
          { "id": "de_c2_v_9", "type": "qcm", "q": "Que signifie « Zwei » ?", "options": ["Un", "Deux", "Quatre"], "a": "Deux" },
          { "id": "de_c2_v_10", "type": "strict", "q": "Traduisez le chiffre : Deux", "a": ["Zwei"] },

          { "type": "card", "id": "de_c2_word_drei", "fr": "Trois (3)", "target": "Drei" },
          { "id": "de_c2_v_11", "type": "qcm", "q": "Que signifie « Drei » ?", "options": ["Trois", "Cinq", "Deux"], "a": "Trois" },
          { "id": "de_c2_v_12", "type": "strict", "q": "Traduisez le chiffre : Trois", "a": ["Drei"] },

          { "id": "de_c2_v_13", "type": "qcm", "hard": true, "q": "Comment dirait-on « Ma famille » ? (indice : meine = ma, Familie est féminin)", "options": ["Meine Familie", "Familie meine", "Eine Familie"], "a": "Meine Familie" },
          { "id": "de_c2_v_14", "type": "strict", "q": "Traduisez : Un, deux, trois", "a": ["Eins, zwei, drei"] },
          { "id": "de_c2_v_15", "type": "qcm", "q": "Quel mot désigne le père en allemand ?", "options": ["Mama", "Papa", "Familie"], "a": "Papa" },
          { "id": "de_c2_v_16", "type": "strict", "hard": true, "q": "Traduisez : Maman et Papa", "a": ["Mama und Papa"] }
        ],
        "grammar": [
          { "type": "gcard", "id": "de_c2_g_card1", "title": "Le pluriel", "content": "L'allemand a plusieurs façons de former le pluriel (souvent avec Umlaut et/ou terminaison) : das Kind → die Kinder (les enfants), die Frau → die Frauen (les femmes). Le pluriel se retient nom par nom." },
          { "id": "de_c2_g_1", "type": "qcm", "q": "Quel est le pluriel de « das Kind » (enfant) ?", "options": ["die Kinder", "die Kinden", "die Kindes"], "a": "die Kinder" },
          { "id": "de_c2_g_2", "type": "strict", "q": "Complétez : die Frau → die Frau___ (les femmes)", "a": ["en"] },

          { "type": "gcard", "id": "de_c2_g_card2", "title": "Les adjectifs possessifs", "content": "Mein/meine (mon/ma) s'accorde avec le genre : mein Vater (masculin), meine Mutter (féminin), mein Kind (neutre). Dein/deine fonctionne pareil pour « ton/ta »." },
          { "id": "de_c2_g_3", "type": "qcm", "q": "Quelle forme utiliser avec « Mutter » (féminin) ?", "options": ["mein Mutter", "meine Mutter", "meinen Mutter"], "a": "meine Mutter" },
          { "id": "de_c2_g_4", "type": "strict", "q": "Traduisez : Mon père (Vater est masculin)", "a": ["Mein Vater"] },
          { "id": "de_c2_g_5", "type": "qcm", "hard": true, "q": "Quelle forme utiliser avec « Kind » (neutre) pour dire « ton enfant » ?", "options": ["dein Kind", "deine Kind", "deinen Kind"], "a": "dein Kind" },

          { "type": "gcard", "id": "de_c2_g_card3", "title": "Les nombres comme adjectifs", "content": "Les nombres précèdent toujours le nom, sans accord de genre : zwei Autos (deux voitures), drei Häuser (trois maisons)." },
          { "id": "de_c2_g_6", "type": "qcm", "q": "Comment dit-on « trois maisons » ?", "options": ["drei Häuser", "Häuser drei", "drei Hausen"], "a": "drei Häuser" },
          { "id": "de_c2_g_7", "type": "strict", "q": "Traduisez : Deux voitures (Auto, pluriel Autos)", "a": ["Zwei Autos"] },
          { "id": "de_c2_g_8", "type": "qcm", "q": "Quelle phrase est correcte ?", "options": ["Meine Familie ist groß", "Familie meine ist groß", "Ist meine Familie groß (affirmatif)"], "a": "Meine Familie ist groß" },
          { "id": "de_c2_g_9", "type": "strict", "hard": true, "q": "Traduisez : Ma famille est grande (groß = grand/grande)", "a": ["Meine Familie ist groß"] },
          { "id": "de_c2_g_10", "type": "qcm", "q": "Quel est l'ordre correct pour « un livre » (Buch, neutre) ?", "options": ["ein Buch", "Buch ein", "eine Buch"], "a": "ein Buch" }
        ],
        "reading": [
          { "type": "gcard", "id": "de_c2_r_intro", "title": "Compréhension : Ma famille", "content": "Lisez le texte suivant :\nIch heiße Lisa. Meine Familie ist nicht groß: Mama, Papa und ich. Wir sind drei. Ich habe auch eine Katze. Eins, zwei, drei - wir sind vier mit der Katze!\n\n(Indice : nicht = ne...pas, habe = a/possède, Katze = chat, vier = quatre)" },
          { "id": "de_c2_r_1", "type": "qcm", "q": "Comment s'appelle la personne qui parle ?", "options": ["Anna", "Lisa", "Erik"], "a": "Lisa" },
          { "id": "de_c2_r_2", "type": "qcm", "q": "Combien de personnes composent la famille (sans le chat) ?", "options": ["Deux", "Trois", "Quatre"], "a": "Trois" },
          { "id": "de_c2_r_3", "type": "strict", "q": "D'après le texte, traduisez : chat", "a": ["Katze"] },
          { "id": "de_c2_r_4", "type": "qcm", "q": "Que signifie « nicht » dans le texte ?", "options": ["ne...pas", "très", "aussi"], "a": "ne...pas" },
          { "id": "de_c2_r_5", "type": "qcm", "hard": true, "q": "Combien sont-ils en comptant le chat ?", "options": ["Trois", "Quatre", "Cinq"], "a": "Quatre" },
          { "id": "de_c2_r_6", "type": "strict", "q": "Traduisez la phrase du texte : Nous sommes trois", "a": ["Wir sind drei"] },
          { "id": "de_c2_r_7", "type": "qcm", "q": "La famille de Lisa est-elle décrite comme grande ?", "options": ["Oui, elle est grande", "Non, elle n'est pas grande", "Ce n'est pas précisé"], "a": "Non, elle n'est pas grande" },
          { "id": "de_c2_r_8", "type": "qcm", "q": "Quel animal Lisa possède-t-elle ?", "options": ["Un chien", "Un chat", "Un oiseau"], "a": "Un chat" },
          { "id": "de_c2_r_9", "type": "strict", "hard": true, "q": "Complétez d'après le texte : « Ich habe auch eine ___ » (chat)", "a": ["Katze"] },
          { "id": "de_c2_r_10", "type": "qcm", "q": "Quel est le sujet principal du texte ?", "options": ["Les nombres", "La présentation de la famille de Lisa", "Les animaux domestiques en Allemagne"], "a": "La présentation de la famille de Lisa" }
        ],
        "review": [
