          { "id": "de_c2_rev_4", "type": "strict", "q": "Traduisez : Ma famille", "a": ["Meine Familie"] },
          { "id": "de_c2_rev_5", "type": "qcm", "hard": true, "q": "Quelle forme possessive pour « Kind » (neutre) : ton enfant ?", "options": ["dein Kind", "deine Kind"], "a": "dein Kind" },
          { "id": "de_c2_rev_6", "type": "strict", "q": "Traduisez : Deux voitures", "a": ["Zwei Autos"] },
          { "id": "de_c2_rev_7", "type": "qcm", "q": "Que signifie « Katze » ?", "options": ["Chien", "Chat", "Oiseau"], "a": "Chat" },
          { "id": "de_c2_rev_8", "type": "strict", "q": "Traduisez : Nous sommes trois", "a": ["Wir sind drei"] },
          { "id": "de_c2_rev_9", "type": "qcm", "hard": true, "q": "Quel est le pluriel de « das Kind » ?", "options": ["die Kinder", "die Kinden", "die Kinds"], "a": "die Kinder" },
          { "id": "de_c2_rev_10", "type": "qcm", "q": "Que signifie « nicht » ?", "options": ["ne...pas", "toujours", "jamais"], "a": "ne...pas" }
